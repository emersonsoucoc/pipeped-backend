generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PROFESSORES ─────────────────────────────────────────────────────
model Professor {
  id         String   @id @default(uuid())
  nome       String
  initials   String
  color      String   @default("#6366F1")
  cpf        String?
  telefone   String?
  email      String?
  titulacao      String   @default("graduacao")
  valorHoraAula  Float    @default(0) @map("valor_hora_aula")
  ativo          Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  disciplinas    ProfessorDisciplina[]
  grades         Grade[]
  substituicoes  Substituicao[] @relation("Substituto")
  ausencias      Substituicao[] @relation("Ausente")

  @@map("professores")
}

// ─── DISCIPLINAS ─────────────────────────────────────────────────────
model Disciplina {
  id        String   @id @default(uuid())
  nome      String   @unique
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  professores ProfessorDisciplina[]

  @@map("disciplinas")
}

// ─── RELAÇÃO N:N PROFESSOR <-> DISCIPLINA ────────────────────────────
model ProfessorDisciplina {
  professorId  String     @map("professor_id")
  disciplinaId String     @map("disciplina_id")
  professor    Professor  @relation(fields: [professorId], references: [id], onDelete: Cascade)
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@id([professorId, disciplinaId])
  @@map("professor_disciplinas")
}

// ─── SEGMENTOS (Infantil, Fund.1, Fund.2, Médio) ────────────────────
model Segmento {
  id        String   @id @default(uuid())
  nome      String
  escolaId  String   @map("escola_id")
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  series Serie[]
  grades Grade[]

  @@unique([escolaId, nome])
  @@index([escolaId])
  @@map("segmentos")
}

// ─── SÉRIES (1º ano, 2º ano, Grupo 3, etc.) ─────────────────────────
model Serie {
  id         String   @id @default(uuid())
  nome       String
  segmentoId String   @map("segmento_id")
  ordem      Int      @default(0)
  ativa      Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  segmento Segmento @relation(fields: [segmentoId], references: [id], onDelete: Cascade)
  turmas   Turma[]
  grades   Grade[]

  @@unique([segmentoId, nome])
  @@index([segmentoId])
  @@map("series")
}

// ─── TURMAS (A, B, C — vinculadas a série) ───────────────────────────
model Turma {
  id       String   @id @default(uuid())
  nome     String
  serieId  String   @map("serie_id")
  turno    String   @default("matutino")  // matutino | vespertino | integral
  ativa    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  serie  Serie   @relation(fields: [serieId], references: [id], onDelete: Cascade)
  grades Grade[]

  @@unique([serieId, nome])
  @@index([serieId])
  @@map("turmas")
}

// ─── GRADES ESCOLARES ────────────────────────────────────────────────
model Grade {
  id             String    @id @default(uuid())
  professorId    String    @map("professor_id")
  disciplina     String
  escolaId       String    @map("escola_id")
  escolaNome     String    @map("escola_nome")
  segmentoId     String?   @map("segmento_id")
  serieId        String?   @map("serie_id")
  turmaId        String?   @map("turma_id")
  totalHoras     Float     @map("total_horas")
  totalAulas     Int       @map("total_aulas")
  status         String    @default("aguardando_rh")
  gradeArray     Json      @map("grade_array")

  // ─── EXTRAS (para fechamento de folha) ─────────
  horasExtras      Float   @default(0) @map("horas_extras")
  coordPedagogica  Float   @default(0) @map("coord_pedagogica")
  substituicoes    Float   @default(0) @map("substituicoes")
  obsExtras        String? @map("obs_extras")

  dataSubmissao  DateTime  @default(now()) @map("data_submissao")
  enviadoPor     String?   @map("enviado_por")
  aprovadoPor    String?   @map("aprovado_por")
  dataAprovacao  DateTime? @map("data_aprovacao")
  observacoes    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  professor Professor  @relation(fields: [professorId], references: [id], onDelete: Cascade)
  segmento  Segmento?  @relation(fields: [segmentoId], references: [id], onDelete: SetNull)
  serie     Serie?     @relation(fields: [serieId], references: [id], onDelete: SetNull)
  turma     Turma?     @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  @@index([professorId])
  @@index([status])
  @@index([escolaId])
  @@index([segmentoId])
  @@index([turmaId])
  @@map("grades")
}

// ─── SUBSTITUIÇÕES (registro de evento) ──────────────────────────────
model Substituicao {
  id              String    @id @default(uuid())
  data            DateTime  @map("data")
  substitutoId    String    @map("substituto_id")
  ausenteId       String    @map("ausente_id")
  escolaId        String    @map("escola_id")
  escolaNome      String    @map("escola_nome")
  turmaId         String?   @map("turma_id")
  turmaNome       String?   @map("turma_nome")
  segmentoNome    String?   @map("segmento_nome")
  disciplina      String
  horarios        Json      @map("horarios")       // [{horario:"07:00"},{horario:"07:50"}]
  totalAulas      Int       @map("total_aulas")
  totalHoras      Float     @map("total_horas")
  motivo          String?                            // falta, licença, atestado, etc.
  observacoes     String?
  registradoPor   String?   @map("registrado_por")
  status          String    @default("registrado")   // registrado | aprovado
  createdAt       DateTime  @default(now()) @map("created_at")

  substituto  Professor @relation("Substituto", fields: [substitutoId], references: [id], onDelete: Cascade)
  ausente     Professor @relation("Ausente", fields: [ausenteId], references: [id], onDelete: Cascade)

  @@index([substitutoId])
  @@index([ausenteId])
  @@index([data])
  @@index([escolaId])
  @@map("substituicoes")
}

// ─── FECHAMENTO DE FOLHA (ciclo mensal, corte dia 25) ────────────────
model FechamentoFolha {
  id             String    @id @default(uuid())
  ciclo          String                             // "2026-04" = 26/Mar-25/Abr
  escolaId       String    @map("escola_id")
  escolaNome     String    @map("escola_nome")
  segmentoId     String?   @map("segmento_id")
  segmentoNome   String?   @map("segmento_nome")
  enviadoPor     String    @map("enviado_por")
  dataEnvio      DateTime  @default(now()) @map("data_envio")
  status         String    @default("enviado")       // enviado | aprovado_rh | devolvido
  snapshot       Json      @map("snapshot")           // cópia dos dados no momento do envio
  obsRh          String?   @map("obs_rh")             // observação do RH se devolver
  aprovadoPor    String?   @map("aprovado_por")
  dataAprovacao  DateTime? @map("data_aprovacao")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([ciclo, escolaId, segmentoId])
  @@index([ciclo])
  @@index([escolaId])
  @@index([status])
  @@map("fechamentos_folha")
}
